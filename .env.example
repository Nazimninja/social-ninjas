# ─────────────────────────────────────────────────────────────────
# Social Ninja's — Environment Variables
# Copy this to .env.local for development
# Add all these to Vercel → Project Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────

# ── AI ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...          # Claude API key (for /api/generate & /api/analysis)

# ── OTP / WhatsApp Verification ────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxx # Twilio Account SID
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxx    # Twilio Auth Token
TWILIO_VERIFY_SERVICE_SID=VAxxxxxx   # Twilio Verify Service SID (WhatsApp channel)

# ── Agency WhatsApp Number ─────────────────────────────────────────
VITE_AGENCY_WHATSAPP=919XXXXXXXXXX    # Agency WhatsApp (country code + number, no +)

# ── Razorpay ───────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx # Razorpay Key ID (for payment verification)
RAZORPAY_KEY_SECRET=xxxxxxxxxxxx      # Razorpay Key Secret
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxx  # Razorpay Webhook Secret (Dashboard → Webhooks)

# ── Admin Panel ────────────────────────────────────────────────────
VITE_ADMIN_PASSWORD=sn@admin2026      # Change this to a strong password!

# ── Google Sheets (Lead logging) ───────────────────────────────────
# Set this in ContentStudioApp.jsx → CONFIG.sheetsWebhook
# Or add as env var:
VITE_SHEETS_WEBHOOK=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# ── Vercel KV (Cross-device trial duplicate check — optional) ──────
# Run: vercel env add KV_REST_API_URL + KV_REST_API_TOKEN after creating a KV store
KV_REST_API_URL=https://xxxx.kv.vercel-storage.com
KV_REST_API_TOKEN=xxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────
# SETUP CHECKLIST:
# [ ] Add ANTHROPIC_API_KEY → AI content generation works
# [ ] Add Twilio vars → Real WhatsApp OTP works (fallback: code 1234 in dev)
# [ ] Add VITE_AGENCY_WHATSAPP → Support link works
# [ ] Add Razorpay vars → Payment verification works (fallback: accepts any pay_* in dev)
# [ ] Change VITE_ADMIN_PASSWORD → Admin panel secured
# [ ] Add Sheets webhook → Lead logging works
# [ ] Razorpay webhook: set https://yourdomain.com/api/razorpay-webhook in Razorpay dashboard
# ─────────────────────────────────────────────────────────────────
