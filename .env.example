# ─────────────────────────────────────────────────────────────────
# Social Ninja's — Environment Variables
# Add ALL of these in: Vercel → Project Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────

# ── AI GENERATION (Required) ──────────────────────────────────────
# Sign up: https://console.anthropic.com → ~$0.003 per generation
ANTHROPIC_API_KEY=sk-ant-...

# ── SMS OTP (Free — 10,000/month) ─────────────────────────────────
# Sign up: https://2factor.in → Dashboard → copy API Key
# If NOT set: dev mode active, anyone can use code "1234"
TWOFACTOR_API_KEY=your_2factor_api_key_here

# ── ADMIN PANEL ───────────────────────────────────────────────────
# Change before going live. Access at: yoursite.com/#/admin
VITE_ADMIN_PASSWORD=sn@admin2026

# ── RAZORPAY (Free signup, 2% per txn) ────────────────────────────
# Sign up: https://razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxx

# ── GOOGLE SHEETS LEADS (Free) ────────────────────────────────────
# Google Sheets + Apps Script = free forever
VITE_SHEETS_WEBHOOK=https://script.google.com/macros/s/YOUR_ID/exec

# ── VERCEL KV (Optional, free 30k reads/mo) ───────────────────────
KV_REST_API_URL=https://xxxx.kv.vercel-storage.com
KV_REST_API_TOKEN=xxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────
# ALL FREE TIERS:
# Vercel Hosting    → Free (100GB/mo)
# Anthropic API     → $5 free credit on signup, then pay-per-use
# 2Factor OTP       → 10,000 OTPs/month FREE
# Razorpay          → Free signup, 2% per transaction only
# Google Sheets     → Free forever
# Vercel KV         → 30,000 reads/month free
# ClickUp CRM       → Free plan (unlimited tasks)
# ─────────────────────────────────────────────────────────────────
